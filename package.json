{
  "name": "action-web-ext",
  "version": "1.3.0",
  "description": "Run a web-ext command",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git://github.com/kewisch/action-web-ext.git"
  },
  "main": "dist/index.cjs",
  "author": "Philipp Kewisch <mozilla@kewis.ch>",
  "license": "MPL-2.0",
  "scripts": {
    "build": "webpack --config webpack.config.cjs",
    "build:dist": "npm run build",
    "lint": "eslint . --ignore-pattern dist/",
    "check:lint": "INPUT_CMD=lint INPUT_SOURCE=test/extension INPUT_CHANNEL=unlisted node dist/index.cjs",
    "check:build": "INPUT_CMD=build INPUT_SOURCE=test/extension INPUT_CHANNEL=unlisted INPUT_ARTIFACTS=web-ext-artifacts node dist/index.cjs",
    "check": "npm run check:lint && npm run check:build"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "jszip": "^3.10.1",
    "sign-addon": "^6.4.0",
    "web-ext": "^10.3.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.1",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  }
}
